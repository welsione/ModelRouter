{
  "providerTemplates": [
    {
      "id": "openai",
      "name": "OpenAI",
      "icon": "/image/openai.png",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyPrefix": "sk-"
    },
    {
      "id": "ollama",
      "name": "Ollama",
      "icon": "/image/ollama.png",
      "baseUrl": "http://localhost:11434/v1",
      "apiKeyPrefix": ""
    },
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "icon": "/image/deepseek.svg",
      "baseUrl": "https://api.deepseek.com/v1",
      "apiKeyPrefix": "sk-"
    },
    {
      "id": "moonshot",
      "name": "Moonshot",
      "icon": "/image/moonshot.png",
      "baseUrl": "https://api.moonshot.cn/v1",
      "apiKeyPrefix": ""
    },
    {
      "id": "qwen",
      "name": "Qwen",
      "icon": "/image/qwen.svg",
      "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "apiKeyPrefix": ""
    },
    {
      "id": "zhipu",
      "name": "智谱AI",
      "icon": "/image/zhipu.svg",
      "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
      "apiKeyPrefix": ""
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "icon": "/image/minimax.svg",
      "baseUrl": "https://api.minimax.chat/v1",
      "apiKeyPrefix": ""
    },
    {
      "id": "siliconflow",
      "name": "SiliconFlow",
      "icon": "/image/siliconflow.jpeg",
      "baseUrl": "https://api.siliconflow.cn/v1",
      "apiKeyPrefix": "sk-"
    }
  ],
  "defaults": {
    "app": {
      "icon": "/image/icon.png",
      "name": "ModelRouter",
      "description": "Your Smart Model Router"
    },
    "server": {
      "port": 8080,
      "logLevel": "DEBUG",
      "cacheExpireMinutes": 5
    },
    "model": {
      "temperature": 0.7,
      "maxTokens": 500,
      "timeoutSeconds": 120
    },
    "router": {
      "modelType": "openai",
      "modelName": "gpt-4o-mini",
      "temperature": 0.7,
      "maxTokens": 500,
      "prompt": "你是一个智能模型路由器。根据用户查询，从候选模型中选择最合适的一个。",
      "responseFormat": "请以JSON格式返回，格式如下：\n{\"selected_model_id\": \"模型ID\", \"reason\": \"选择理由\"}"
    },
    "strategy": {
      "maxContextTokens": 4096,
      "temperature": 0.7,
      "timeoutSeconds": 120,
      "enableStream": false,
      "priority": 50,
      "weight": 1.0,
      "enabled": true
    },
    "candidate": {
      "priority": 50,
      "weight": 1.0,
      "enabled": true
    }
  },
  "options": {
    "logLevels": ["DEBUG", "INFO", "WARN", "ERROR"],
    "temperatureRange": {
      "min": 0,
      "max": 2,
      "step": 0.1
    }
  },
  "ui": {
    "latencyThresholds": {
      "good": 1000,
      "medium": 3000
    },
    "modelTypeColors": {
      "openai": {
        "light": "bg-green-100 text-green-700",
        "dark": "dark:bg-green-900 dark:text-green-300"
      },
      "ollama": {
        "light": "bg-purple-100 text-purple-700",
        "dark": "dark:bg-purple-900 dark:text-purple-300"
      },
      "cloud": {
        "light": "bg-blue-100 text-blue-700",
        "dark": "dark:bg-blue-900 dark:text-blue-300"
      },
      "default": {
        "light": "bg-gray-100 text-gray-700",
        "dark": ""
      }
    },
    "chatTest": {
      "welcomeMessage": "你好！我是你的 AI 助手。有什么可以帮你的吗？"
    }
  },
  "about": {
    "version": "1.0.0",
    "build": "React + Electron",
    "database": "JSON File"
  },
  "aiPrompts": {
    "strategyRulePrompt": "请帮我生成路由策略的选择规则。选择规则用于在多个候选模型中选择最合适的一个。\n\n请用中文生成，选择规则应该：\n1. 根据问题复杂度选择（简单问题用轻量快速模型，复杂问题用强力模型）\n2. 根据问题类型选择（代码问题用编程模型，数学问题用数学模型）\n3. 综合考虑性能、价格、响应速度等因素\n\n只需要返回选择规则内容，不要其他解释。",
    "strategyRuleDefault": "请根据以下候选模型的特点和用户问题，从中选择最合适的模型。\n1. 根据问题复杂度选择：简单问题用轻量快速模型，复杂问题用强力模型\n2. 根据问题类型选择：代码问题用编程模型，数学问题用数学模型\n3. 综合考虑性能、价格、响应速度等因素",
    "candidateDescription": "请帮我为模型 \"{modelName}\" 生成一段简洁的描述（不超过100字），用于帮助AI路由决策时理解该模型的特点和适用场景。请用中文返回，只需要返回描述内容，不要其他解释。",
    "outputFormat": "请以JSON格式返回，必须包含以下字段：{\"selected_model_id\": \"模型ID\", \"reason\": \"选择理由\"}"
  }
}
